# CapitalOps Backend — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/capitalops

# Shared secret for the GUI compatibility layer (/api/* routes).
# Must match COMPAT_API_KEY in the frontend Express server's environment.
# If not set, compat mutation routes are open (acceptable for local dev only).
COMPAT_API_KEY=change-me-in-production

# JWT signing secret for /api/v1/ routes (used by direct API clients)
# Required in production — set a strong random value.
JWT_SECRET_KEY=change-me-in-production

# CORS: comma-separated list of allowed frontend origins
# Set to your deployed frontend URL in production.
FRONTEND_ORIGIN=http://localhost:5000,http://localhost:5173

# Set to "development" to enable auto-seeding of demo data on startup.
# Set to "production" to disable seeding permanently.
FLASK_ENV=development

# ============================================================================
# AWS S3 Configuration (Phase 4 - Profile Image Upload)
# ============================================================================

# AWS credentials for S3 file uploads
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# S3 bucket name for uploads
AWS_BUCKET_NAME=your-bucket-name

# ============================================================================
# Entitlement Status Polling (Accela + ArcGIS)
# ============================================================================
# Poller runs as a background job every N minutes.
# Only starts when FLASK_ENV is not 'testing'.

# Minutes between poll cycles (default: 30)
POLLER_INTERVAL_MINUTES=30

# Accela Civic Platform API — used by Hillsborough and Pinellas counties
# Register at developer.accela.com to obtain credentials.
ACCELA_BASE_URL=https://apis.accela.com
ACCELA_CLIENT_ID=        # From Accela developer portal
ACCELA_CLIENT_SECRET=    # From Accela developer portal

# Agency identifiers for each county (used in Accela API paths)
ACCELA_HILLSBOROUGH_AGENCY=hillsboroughcountyfl
ACCELA_PINELLAS_AGENCY=pinellascountyfl

# ArcGIS FeatureServer base URLs for zoning hearings and rezoning data.
# The specific layer paths must be confirmed against live county GeoHub portals.
# Example full URL: https://maps.hcfl.gov/arcgis/rest/services/Planning/ZoningHearings/FeatureServer/0
HILLSBOROUGH_ARCGIS_HEARINGS_URL=
PINELLAS_ARCGIS_HEARINGS_URL=

# Field name used for parcel number filtering in ArcGIS queries
# (default: PARCEL_NUM — confirm against the live service schema)
ARCGIS_PARCEL_FIELD=PARCEL_NUM
